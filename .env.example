# Environment variables for Lootopia Frontend

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Geolocation
NEXT_PUBLIC_ENABLE_GEOLOCATION=true

# Maps Configuration
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AR.js Configuration
NEXT_PUBLIC_AR_JS_LIBRARY=https://cdn.jsdelivr.net/npm/@ar-js-org/ar.js@3.4.5/aframe/aframe-ar.min.js

# App Configuration
NEXT_PUBLIC_APP_NAME=Lootopia
NEXT_PUBLIC_APP_VERSION=0.1.0

# Mock Data
# Set to true to force the frontend to use mock chases even if the API is reachable.
NEXT_PUBLIC_USE_MOCK_CHASES=true

# Set to true to force the profile/leaderboard to use mock gamification data.
NEXT_PUBLIC_USE_MOCK_GAMIFICATION=true
