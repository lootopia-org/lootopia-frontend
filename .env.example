# Lootopia Frontend — production API (no mocks)
NEXT_PUBLIC_API_URL=https://api.wookiesrpeople2.dev
NEXT_PUBLIC_APP_DOWNLOAD_URL=https://your-server.com/lootopia.apk
NEXT_PUBLIC_APP_NAME=Lootopia

# HTTPS base for photo-capture QR codes (LAN IP / tunnel — not localhost if scanning from a phone)
NEXT_PUBLIC_WEB_URL=http://192.168.1.13:3000

# Expo Go + tunnel — synced automatically via `npm run sync:tunnel-env` in lootopia-mobile.
# The hunt wizard QR encodes this exp:// URL directly (not the web /capture page).
#   NEXT_PUBLIC_MOBILE_CAPTURE_LINK=exp://YOUR-TUNNEL.exp.direct/--/capture/{sessionId}

# Server-side proxy target (optional override)
BACKEND_API_URL=https://api.wookiesrpeople2.dev
